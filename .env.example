# Database
DATABASE_URL="postgresql://..."

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SECRET=whsec_...

# Resend Email
RESEND_API_KEY=re_...

# Paystack
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_SECRET_KEY=sk_test_...

# Live Sessions WebSocket (Railway)
# Set on VERCEL — HTTP base URL of the Railway WS service (no trailing slash)
LIVE_SESSIONS_WS_HTTP_URL=https://your-service.up.railway.app
# Set on VERCEL + RAILWAY — must match on both sides
BROADCAST_SECRET=replace_with_a_long_random_secret
# Set on VERCEL — public WSS URL for the browser client
NEXT_PUBLIC_LIVE_SESSIONS_WS_URL=wss://your-service.up.railway.app/live-sessions
# Set on RAILWAY only — overridden by $PORT automatically, kept for local dev
LIVE_SESSIONS_WS_PORT=4001